# Paste the ADO.NET connection string directly from the Azure portal
# (Azure SQL Database → Connection strings → ADO.NET)
AZURE_SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-database;Persist Security Info=False;User ID=your-email@domain.com;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# MCP server port (default 8000)
PORT=8000
